{
    "version": 2,
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.8.0",
            "includeFiles": "resources/views/**"
        }
    },
    "routes": [
        {
            "src": "/(css|js|images|favicon.ico|robots.txt)(.*)",
            "dest": "/public/$1$2"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "buildCommand": "npm run build",
    "outputDirectory": "public"
}